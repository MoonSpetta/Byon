<!-- res/drawable/bg_banner_gold_accent.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Layer 1: Gradien latar dari gelap ke lebih terang -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#1A1A2E"
                android:endColor="#2C2C3A"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Layer 2: Garis aksen emas di bagian bawah (opsional) -->
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="3dp" />
            <solid android:color="#FFD700" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Layer 3: Sedikit efek "glow" emas di sudut kiri atas (motif promo) -->
    <item android:gravity="top|start" android:top="-20dp" android:left="-20dp">
        <shape android:shape="oval">
            <size android:width="80dp" android:height="80dp" />
            <solid android:color="#20FFD700" />
        </shape>
    </item>
</layer-list>