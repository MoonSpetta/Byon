<!-- res/drawable/bg_search_bar.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Sudut membulat. Setengah dari tinggi LinearLayout (52dp) -->
    <corners android:radius="26dp" />

    <!-- Warna latar belakang search bar (bisa disesuaikan) -->
    <solid android:color="#2C2C3A" />

    <!-- Opsional: Stroke (garis tepi) -->
    <stroke
        android:width="1dp"
        android:color="#4A4A5A" />
</shape>