<!-- res/drawable/bg_button_logout.xml -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Sudut membulat -->
    <corners android:radius="30dp" />

    <!-- Warna latar belakang tombol (merah hati atau abu gelap, sesuai selera)
         Saya gunakan warna merah lembut untuk efek logout, tapi Anda bisa ganti -->
    <solid android:color="#D32F2F" />

    <!-- Stroke tepi (opsional) -->
    <stroke
        android:width="1dp"
        android:color="#FFD700" />

    <!-- Padding agar teks tidak terlalu mepet -->
    <padding
        android:left="16dp"
        android:right="16dp"
        android:top="10dp"
        android:bottom="10dp" />

</shape>